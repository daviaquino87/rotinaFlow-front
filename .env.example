# ============================================
# SERVER / VITE
# ============================================
PORT=5173
BASE_PATH=/

# ============================================
# API CONFIGURATION
# ============================================
# Deixe vazio (ou remova) para usar o proxy do Vite no desenvolvimento.
# O proxy redireciona /api → http://localhost:3000 automaticamente.
# Em produção, aponte para a URL pública do backend.
VITE_API_BASE_URL=

# Exemplo para produção:
# VITE_API_BASE_URL=https://api.rotinaflow.com.br

# ============================================
# STRIPE (Frontend)
# ============================================
# Chave pública do Stripe (Publishable Key).
# Obter em: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ============================================
# OPTIONAL / DEVELOPMENT
# ============================================
# Habilite quando usar WSL ou Docker Desktop no Windows/Mac e o
# hot-reload não funcionar automaticamente
CHOKIDAR_USEPOLLING=false
